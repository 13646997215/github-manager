{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow Manifest",
  "type": "object",
  "required": ["name", "category", "expected_candidates", "verification"],
  "properties": {
    "name": {"type": "string"},
    "category": {"type": "string"},
    "expected_candidates": {"type": "array", "items": {"type": "string"}},
    "expected_next_probe": {"type": "string"},
    "verification": {"type": "string"}
  }
}
